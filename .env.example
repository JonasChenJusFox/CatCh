##########################
# Auth Service
##########################

PASSWORD_HASH_ITERATIONS=210000
VERIFICATION_CODE_LENGTH=6
VERIFICATION_CODE_TTL_MINUTES=10
VERIFICATION_CODE_MAX_ATTEMPTS=5
VERIFICATION_CODE_PEPPER=YOUR_LONG_RANDOM_VERIFICATION_CODE_PEPPER
VERIFICATION_CODE_DELIVERY=smtp

# SMTP-only verification-code delivery. For Gmail, use an App Password,
# not your normal Google account password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=YOUR_EMAIL@gmail.com
SMTP_PASSWORD=YOUR_SMTP_OR_APP_PASSWORD
SMTP_FROM_EMAIL=YOUR_EMAIL@gmail.com
SMTP_FROM_NAME=CatCh
SMTP_REPLY_TO=YOUR_EMAIL@gmail.com
SMTP_USE_TLS=true
SMTP_TIMEOUT_SECONDS=5

##########################
# JWT configuration shared by services
##########################

JWT_SECRET=YOUR_JWT_SECRET
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

##########################
# Service URLs on DigitalOcean
##########################

# DigitalOcean App Platform component URLs. Update the route suffixes if your
# component routes differ in the DigitalOcean dashboard.
GRADER_SERVICE_URL=https://catch-bpp85.ondigitalocean.app/catch-grader-service
GAME_SERVICE_URL=https://catch-bpp85.ondigitalocean.app/catch-game-service
TEACHER_SERVICE_URL=https://catch-bpp85.ondigitalocean.app/catch-teacher-service
AUTH_SERVICE_URL=https://catch-bpp85.ondigitalocean.app/catch-auth-service
FRONTEND_URL=https://catch-bpp85.ondigitalocean.app

# Vite embeds these frontend API URLs at build time.
VITE_GAME_SERVICE_URL=https://catch-bpp85.ondigitalocean.app/catch-game-service
VITE_AUTH_SERVICE_URL=https://catch-bpp85.ondigitalocean.app/catch-auth-service
VITE_TEACHER_SERVICE_URL=https://catch-bpp85.ondigitalocean.app/catch-teacher-service

##########################
# Game Service
##########################

GAME_SERVICE_PORT=8000
DB_BACKEND=mongo

MONGO_URL=mongodb+srv://YOUR_MONGO_USERNAME:YOUR_MONGO_PASSWORD@cluster0.p4np4q5.mongodb.net/?retryWrites=true&w=majority&appName=Cluster0
MONGO_DB=fish_likes_cat
MONGO_INITDB_ROOT_PASSWORD=YOUR_LOCAL_MONGO_ROOT_PASSWORD

# CORS origins only include scheme + host + optional port. Do not include
# component paths like /catch-frontend here.
ALLOWED_ORIGINS=https://catch-bpp85.ondigitalocean.app,http://localhost:3000,http://localhost:5173

PROBLEM_DATASET_PATH=

LOG_LEVEL=INFO

##########################
# Grader Service
##########################

GRADER_TIMEOUT_SECONDS=10

##########################
# Web App
##########################

WEB_APP_PORT=3000
